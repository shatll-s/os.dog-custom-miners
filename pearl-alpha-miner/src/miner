#!/bin/bash
####################################################################################
###
### pearl-alpha-miner GPU miner
### os.dog integration: @osdog
###
####################################################################################
###
### Multi-pool failover:
###   profile .pool       = primary pool (single URL)
###   profile .addition   = extra "--pool URL" tokens for failover backups
###                         + optional FAILOVER_*=N tunables
###
### Example .addition:
###   --pool stratum+tcp://us2.alphapool.tech:5566 --pool stratum+tcp://sg1.alphapool.tech:5566
###
### Failover tunables (env or in .addition):
###   FAILOVER_GRACE_SEC=120   no-share window forgiven after launch
###   FAILOVER_DEAD_SEC=240    pool declared dead after this long without accepted shares
###   FAILOVER_RETURN_SEC=1800 attempt to return to primary after this long on a backup
###   FAILOVER_POLL_SEC=15     supervisor poll interval
###
####################################################################################

cd `dirname $0`
. ./utils.sh

PROFILE="$1"
if [[ -z "$PROFILE" || ! -f "$PROFILE" ]]; then
    echo "Usage: ./miner /path/to/profile.json"
    exit 1
fi

POOL=$(jq -r '.pool // empty' "$PROFILE")
TEMPLATE=$(jq -r '.template // empty' "$PROFILE")
ADDITION=$(jq -r '.addition // empty' "$PROFILE")

LOG="/var/log/osdog/miners/pearl-alpha-miner.log"
mkdir -p /var/log/osdog/miners

ADDITION="${ADDITION%%#*}"

# Pre-pass: extract every "--pool URL" (or "--pool=URL") from ADDITION as
# a backup pool, leave the rest of the tokens for downstream parsing.
declare -a EXTRA_POOLS=()
declare -a CLEANED=()
read -ra _tokens <<< "$ADDITION"
i=0
while (( i < ${#_tokens[@]} )); do
    t="${_tokens[i]}"
    if [[ "$t" == "--pool" ]]; then
        if (( i + 1 < ${#_tokens[@]} )); then
            EXTRA_POOLS+=("${_tokens[i+1]}")
            ((i+=2)); continue
        fi
    elif [[ "$t" == --pool=* ]]; then
        EXTRA_POOLS+=("${t#--pool=}")
        ((i++)); continue
    fi
    # Extract FAILOVER_*=N wrapper config into env, drop from passthrough
    if [[ "$t" =~ ^FAILOVER_[A-Z_]+=[0-9]+$ ]]; then
        export "$t"
        ((i++)); continue
    fi
    CLEANED+=("$t")
    ((i++))
done

cleaned_addition="${CLEANED[*]}"

REMAINING_ARGS=""
parse_args "$cleaned_addition" devices
remainingAddition=$REMAINING_ARGS

# Build POOLS[] = [profile.pool] + EXTRA_POOLS (skip empties, dedup-trivially)
declare -a POOLS=()
[[ -n "$POOL" ]] && POOLS+=("$POOL")
for p in "${EXTRA_POOLS[@]}"; do
    [[ -n "$p" ]] && POOLS+=("$p")
done

# Default to alphapool primary if nothing was provided
if [[ ${#POOLS[@]} -eq 0 ]]; then
    POOLS=("stratum+tcp://eu1.alphapool.tech:5566")
fi

n=${#POOLS[@]}

echo "> additional args: $ADDITION"
echo "> remaining args: $remainingAddition"
echo "> Starting pearl-alpha-miner"
echo "> Pools (${n}): ${POOLS[*]}"
echo "> Address: $TEMPLATE"

# Required for GPU index ↔ PCI bus id mapping in stats
export CUDA_DEVICE_ORDER=PCI_BUS_ID

# Truncate at start, then append all output (ours + miner's) to log via tee
: > "$LOG"
exec > >(exec tee -a "$LOG") 2>&1

build_batch() {
    local pool="$1"
    batch=( ./alpha-miner --pool "$pool" --address "$TEMPLATE" --status-interval 30 --color never )
    [[ -n "$devices" ]] && batch+=( --devices "$devices" )
    [[ -n "$remainingAddition" ]] && batch+=( $remainingAddition )
}

# Single-pool: just exec the miner directly (no supervisor needed)
if [[ $n -eq 1 ]]; then
    date +%s > /tmp/pearl-alpha-miner.start
    build_batch "${POOLS[0]}"
    echo "${batch[*]}"
    exec "${batch[@]}"
fi

# ---------------------------------------------------------------------------
# Multi-pool failover supervisor (modelled after hive alpha-supervise.sh)
# ---------------------------------------------------------------------------
: "${FAILOVER_GRACE_SEC:=120}"
: "${FAILOVER_DEAD_SEC:=240}"
: "${FAILOVER_RETURN_SEC:=1800}"
: "${FAILOVER_POLL_SEC:=15}"

echo "> Supervisor: grace=${FAILOVER_GRACE_SEC}s dead=${FAILOVER_DEAD_SEC}s return=${FAILOVER_RETURN_SEC}s poll=${FAILOVER_POLL_SEC}s"

miner_pid=""

stop_miner() {
    [[ -z "$miner_pid" ]] && return
    kill -INT "$miner_pid" 2>/dev/null
    for _ in $(seq 1 12); do
        kill -0 "$miner_pid" 2>/dev/null || break
        sleep 1
    done
    kill -KILL "$miner_pid" 2>/dev/null
    wait "$miner_pid" 2>/dev/null
    miner_pid=""
}

on_stop() {
    trap - INT TERM
    echo "$(date -u +%FT%TZ) [wrapper] stop signal — shutting down miner"
    stop_miner
    exit 0
}
trap on_stop INT TERM

now() { date +%s; }

# Epoch of the most recent accepted-share line in the log, or 0
last_share_epoch() {
    local ts
    ts=$(tail -n 8000 "$LOG" 2>/dev/null \
         | sed -E 's/\x1B\[[0-9;]*[a-zA-Z]//g' \
         | grep -aE 'component=share submitted' \
         | tail -n 1 \
         | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}')
    if [[ -n "$ts" ]]; then
        date -d "${ts}Z" +%s 2>/dev/null || echo 0
    else
        echo 0
    fi
}

idx=0
primary_retry_at=$(( $(now) + FAILOVER_RETURN_SEC ))

while :; do
    pool="${POOLS[$idx]}"
    echo "$(date -u +%FT%TZ) [wrapper] launching miner on pool[$idx]=$pool"
    date +%s > /tmp/pearl-alpha-miner.start

    build_batch "$pool"
    "${batch[@]}" &
    miner_pid=$!
    launch=$(now)
    rotate=""

    while :; do
        sleep "$FAILOVER_POLL_SEC" &
        wait $!

        if ! kill -0 "$miner_pid" 2>/dev/null; then
            wait "$miner_pid" 2>/dev/null
            echo "$(date -u +%FT%TZ) [wrapper] miner exited on pool[$idx] — rotating"
            rotate="next"; break
        fi

        t=$(now)
        ls=$(last_share_epoch)
        (( ls < launch )) && ls=$launch

        if (( t - launch > FAILOVER_GRACE_SEC )) && (( t - ls > FAILOVER_DEAD_SEC )); then
            echo "$(date -u +%FT%TZ) [wrapper] pool[$idx]=$pool DEAD — no share for $((t-ls))s; failing over"
            rotate="next"; break
        fi

        if (( idx != 0 )) && (( t >= primary_retry_at )); then
            echo "$(date -u +%FT%TZ) [wrapper] scheduled retry of primary pool[0]"
            rotate="primary"; break
        fi
    done

    stop_miner

    if [[ "$rotate" == "primary" ]]; then
        idx=0
    else
        idx=$(( (idx + 1) % n ))
    fi
    (( idx == 0 )) && primary_retry_at=$(( $(now) + FAILOVER_RETURN_SEC ))

    sleep 2
done
