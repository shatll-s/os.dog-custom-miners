#!/bin/bash

####################################################################################
###
### rgminer GPU stats
### os.dog integration: @osdog
###
####################################################################################

# os.dog stats output format:
# {
#   "miner": "rgminer",
#   "algo": "pearl",
#   "ver": "0.8.8",
#   "online": 1711234567,
#   "total_hr": "25345148",
#   "total_share": "31",
#   "total_badshare": "0",
#   "hr": [3169026, 3168905, ...],
#   "share": [6, 5, 2, ...],
#   "badshare": [0, 0, 0, ...],
#   "busid": {"0":"01","1":"02",...}
# }

cd `dirname $0`

PROFILE="$1"
[[ -z "$PROFILE" || ! -f "$PROFILE" ]] && echo "Usage: $0 <profile.json>" && exit 1

API_PORT=$(jq -r '.api_port // 9200' "$PROFILE")
# Extract --algo from .addition (profile.algo is os.dog display, not miner runtime)
ADDITION=$(jq -r '.addition // empty' "$PROFILE")
ALGO=$(echo "$ADDITION" | awk '{
    for (i=1; i<=NF; i++) {
        if ($i ~ /^--algo=/) { sub(/^--algo=/, "", $i); print $i; exit }
        if ($i == "--algo" && (i+1) <= NF)  { print $(i+1); exit }
    }
}')
[[ -z "$ALGO" ]] && ALGO="pearl"

miner="rgminer"
ver="0.8.8"
API_TIMEOUT=3

api_json=$(curl -s --connect-timeout 2 --max-time $API_TIMEOUT "http://127.0.0.1:$API_PORT/metrics" 2>/dev/null)
[[ -z "$api_json" ]] && exit 1

# Per-GPU arrays from .miners[]
hr_json=$(echo "$api_json" | jq '[.miners[]?.emaRate // 0 | floor]')
share_json=$(echo "$api_json" | jq '[.miners[]?.acceptedShares // 0]')
badshare_json=$(echo "$api_json" | jq '[.miners[]?.rejectedShares // 0]')

# Totals
total_hr=$(echo "$api_json" | jq '[.miners[]?.emaRate // 0] | add | floor // 0')
total_share=$(echo "$api_json" | jq '[.miners[]?.acceptedShares // 0] | add // 0')
total_badshare=$(echo "$api_json" | jq '[.miners[]?.rejectedShares // 0] | add // 0')

[[ -z "$hr_json" || "$hr_json" == "null" ]] && hr_json='[]'
[[ -z "$share_json" || "$share_json" == "null" ]] && share_json='[]'
[[ -z "$badshare_json" || "$badshare_json" == "null" ]] && badshare_json='[]'
[[ -z "$total_hr" || "$total_hr" == "null" ]] && total_hr=0
[[ -z "$total_share" || "$total_share" == "null" ]] && total_share=0
[[ -z "$total_badshare" || "$total_badshare" == "null" ]] && total_badshare=0

# Bus IDs from nvidia-smi (same approach as other miners)
busid_json='{}'
if command -v nvidia-smi >/dev/null 2>&1; then
    mapfile -t bus_lines < <(nvidia-smi --query-gpu=pci.bus_id --format=csv,noheader 2>/dev/null)
    for ((i=0; i<${#bus_lines[@]}; i++)); do
        busid_raw=$(echo "${bus_lines[$i]}" | cut -d':' -f2 | tr '[:upper:]' '[:lower:]' | tr -d ' ')
        [[ ${#busid_raw} -eq 1 ]] && busid_raw="0$busid_raw"
        busid_json=$(jq -n --argjson data "$busid_json" --arg key "$i" --arg value "$busid_raw" \
            '$data + { ($key): $value }')
    done
fi

# Uptime from rgminer process etimes (works across rgminer's internal restarts)
miner_online=""
if command -v pgrep >/dev/null 2>&1; then
    pid=$(pgrep -f "./rgminer" | head -1)
    if [[ -n "$pid" ]]; then
        etimes=$(ps -p "$pid" -o etimes= 2>/dev/null | tr -d ' ')
        if [[ "$etimes" =~ ^[0-9]+$ ]]; then
            miner_online=$(( $(date +%s) - etimes ))
        fi
    fi
fi

# Build output JSON
miner_json=$(jq -n \
    --arg miner "$miner" \
    --arg algo "$ALGO" \
    --arg ver "$ver" \
    --arg total_hr "$total_hr" \
    --arg total_share "$total_share" \
    --arg total_badshare "$total_badshare" \
    --argjson hr "$hr_json" \
    --argjson share "$share_json" \
    --argjson badshare "$badshare_json" \
    --argjson busid "$busid_json" \
    '{$miner, $algo, $ver, $total_hr, $total_share, $total_badshare, $hr, $share, $badshare, $busid}')

[[ -n "$miner_online" ]] && miner_json=$(jq ". + {\"online\": \"$miner_online\"}" <<< "$miner_json")

echo "$miner_json" | jq -c '.'
