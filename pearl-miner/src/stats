#!/bin/bash

####################################################################################
###
### pearl-miner GPU stats
### os.dog integration: @osdog
###
####################################################################################

# os.dog stats output format:
# {
#   "miner": "pearl-miner",
#   "algo": "pearl",
#   "ver": "1.0.0",
#   "online": 1711234567,
#   "total_hr": "25345148",
#   "total_share": "31",
#   "total_badshare": "0",
#   "hr": [3169026, 3168905, ...],
#   "share": [6, 5, 2, ...],
#   "badshare": [0, 0, 0, ...],
#   "busid": {"0":"01","1":"02",...}
# }

cd `dirname $0`

PROFILE="$1"
[[ -z "$PROFILE" || ! -f "$PROFILE" ]] && echo "Usage: $0 <profile.json>" && exit 1

miner="pearl-miner"
algo="pearl"
ver="10.0"
LOG="/var/log/osdog/miners/pearl-miner.log"

[[ ! -f "$LOG" ]] && exit 1

# Fill JSON array of `count` zeros
fill_zeros() {
    local count="$1"
    [[ "$count" -le 0 ]] && echo '[]' && return
    local out="["
    for ((i=0; i<count; i++)); do
        [[ $i -gt 0 ]] && out+=","
        out+="0"
    done
    out+="]"
    echo "$out"
}

# Detect GPUs and bus IDs
gpu_count=0
busid_json='{}'

if command -v nvidia-smi >/dev/null 2>&1; then
    mapfile -t bus_lines < <(nvidia-smi --query-gpu=pci.bus_id --format=csv,noheader 2>/dev/null)
    gpu_count=${#bus_lines[@]}

    for ((i=0; i<gpu_count; i++)); do
        busid_raw=$(echo "${bus_lines[$i]}" | cut -d':' -f2 | tr '[:upper:]' '[:lower:]' | tr -d ' ')
        [[ ${#busid_raw} -eq 1 ]] && busid_raw="0$busid_raw"
        busid_json=$(jq -n --argjson data "$busid_json" --arg key "$i" --arg value "$busid_raw" \
            '$data + { ($key): $value }')
    done
fi

# Parse hashrate from log: "Hashrate GPU #N = X <unit>"  (with or without space after #)
parsed=$(tail -n 1000 "$LOG" | awk -v gpu_count="$gpu_count" '
    function multiplier(unit) {
        if (unit == "TH/s") return 1000000000000
        if (unit == "GH/s") return 1000000000
        if (unit == "MH/s") return 1000000
        if (unit == "KH/s" || unit == "kH/s") return 1000
        return 1
    }
    /Hashrate GPU #[[:space:]]*[0-9]+[[:space:]]*=/ {
        gpu = $0
        sub(/^.*GPU #[[:space:]]*/, "", gpu)
        sub(/[[:space:]].*$/, "", gpu)
        value = $0
        sub(/^.*=[[:space:]]*/, "", value)
        split(value, parts, " ")
        hs[gpu+0] = int(parts[1] * multiplier(parts[2]))
        if ((gpu+0) > max_gpu) max_gpu = gpu+0
    }
    END {
        last = (gpu_count > 0) ? gpu_count - 1 : max_gpu
        printf "["
        total = 0
        for (i = 0; i <= last; i++) {
            rate = hs[i] + 0
            total += rate
            printf "%s%d", (i == 0 ? "" : ","), rate
        }
        printf "]|%d\n", total
    }
')

IFS='|' read -r hr_json total_hr <<< "$parsed"
[[ -z "$hr_json" || "$hr_json" == "[]" ]] && hr_json=$(fill_zeros "$gpu_count")
[[ -z "$total_hr" ]] && total_hr=0

# Shares — miner doesn't expose them; fill with zeros
share_json=$(fill_zeros "$gpu_count")
badshare_json=$(fill_zeros "$gpu_count")
total_share=0
total_badshare=0

# Uptime: read from start file written by miner script
miner_online=""
[[ -f /tmp/pearl-miner.start ]] && miner_online=$(cat /tmp/pearl-miner.start)

# Build output JSON
miner_json=$(jq -n \
    --arg miner "$miner" \
    --arg algo "$algo" \
    --arg ver "$ver" \
    --arg total_hr "$total_hr" \
    --arg total_share "$total_share" \
    --arg total_badshare "$total_badshare" \
    --argjson hr "$hr_json" \
    --argjson share "$share_json" \
    --argjson badshare "$badshare_json" \
    --argjson busid "$busid_json" \
    '{$miner, $algo, $ver, $total_hr, $total_share, $total_badshare, $hr, $share, $badshare, $busid}')

[[ -n "$miner_online" ]] && miner_json=$(jq ". + {\"online\": \"$miner_online\"}" <<< "$miner_json")

echo "$miner_json" | jq -c '.'
