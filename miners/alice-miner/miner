#!/bin/bash
cd "$(dirname "$0")"

PROFILE="$1"
[[ -z "$PROFILE" || ! -f "$PROFILE" ]] && echo "Usage: $0 <profile.json>" && exit 1

WALLET=$(jq -r '.template // .wallet // empty' "$PROFILE")
POOL=$(jq -r '.pool // empty' "$PROFILE")
ADDITION=$(jq -r '.addition // empty' "$PROFILE")

[[ -z "$WALLET" ]] && echo "ERROR: No wallet address in profile" && exit 1

LOG="/var/log/osdog/miners/alice-miner.log"
VENV_DIR="./venv"
MINER_DIR="./alice-src"

setup_environment() {
    if [[ ! -d "$VENV_DIR" ]]; then
        echo "> Setting up Python environment..."
        python3 -m venv "$VENV_DIR"
        source "$VENV_DIR/bin/activate"
        pip install --upgrade pip
        pip install torch --index-url https://download.pytorch.org/whl/cu121
        pip install numpy requests "substrate-interface>=1.8.0" "psutil>=5.9.0"
        deactivate
        echo "> Environment ready"
    fi

    if [[ ! -f "$MINER_DIR/alice_miner_v2.py" ]]; then
        echo "> Downloading Alice Miner..."
        git clone https://github.com/V-SK/Alice-Miner.git "$MINER_DIR"
        apply_8gb_patch
        echo "> Alice Miner ready"
    fi
}

apply_8gb_patch() {
    echo "> Applying gradient checkpointing patch for 8GB GPUs..."
    local target="$MINER_DIR/alice_miner_v2.py"
    [[ ! -f "$target" ]] && return

    sed -i 's/per_layer_gb = 0\.85/per_layer_gb = 0.45/' "$target"
    sed -i 's/fixed_overhead = 1\.5/fixed_overhead = 2.0/' "$target"
    echo "> Patch applied: per_layer_gb=0.45, fixed_overhead=2.0"
}

detect_gpus() {
    local count
    count=$(nvidia-smi --query-gpu=index --format=csv,noheader 2>/dev/null | wc -l)
    echo "${count:-0}"
}

setup_environment

source "$VENV_DIR/bin/activate"

PS_URL="${POOL:-https://ps.aliceprotocol.org}"
GPU_COUNT=$(detect_gpus)

echo "> Alice Protocol Miner"
echo "> Wallet: $WALLET"
echo "> PS URL: $PS_URL"
echo "> GPUs detected: $GPU_COUNT"
echo "> Extra flags: $ADDITION"

if [[ "$GPU_COUNT" -le 1 ]]; then
    batch="python3 $MINER_DIR/alice_miner_v2.py"
    batch+=" --ps-url $PS_URL"
    batch+=" --address $WALLET"
    batch+=" --precision fp16"

    MEM_GB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1)
    MEM_GB=$((${MEM_GB:-0} / 1024))
    if [[ "$MEM_GB" -lt 12 ]]; then
        batch+=" --batch-size 1 --seq-len 64"
        echo "> Low VRAM mode: batch-size=1, seq-len=64"
    fi

    [[ -n "$ADDITION" ]] && batch+=" $ADDITION"

    echo "> Starting: $batch"
    unbuffer $batch 2>&1 | tee "$LOG"
else
    echo "> Multi-GPU mode: launching $GPU_COUNT instances"
    PIDS=()
    for GPU_ID in $(nvidia-smi --query-gpu=index --format=csv,noheader); do
        MEM_GB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits -i "$GPU_ID" 2>/dev/null)
        MEM_GB=$((${MEM_GB:-0} / 1024))

        batch="python3 $MINER_DIR/alice_miner_v2.py"
        batch+=" --ps-url $PS_URL"
        batch+=" --address $WALLET"
        batch+=" --instance-id gpu${GPU_ID}"
        batch+=" --precision fp16"

        if [[ "$MEM_GB" -lt 12 ]]; then
            batch+=" --batch-size 1 --seq-len 64"
        fi

        [[ -n "$ADDITION" ]] && batch+=" $ADDITION"

        GPU_LOG="/var/log/osdog/miners/alice-miner-gpu${GPU_ID}.log"
        echo "> GPU $GPU_ID (${MEM_GB}GB): $batch"
        CUDA_VISIBLE_DEVICES=$GPU_ID $batch 2>&1 | tee "$GPU_LOG" &
        PIDS+=($!)
    done

    for pid in "${PIDS[@]}"; do
        wait "$pid"
    done
fi
