#!/bin/bash

####################################################################################
###
### ninja-miner GPU stats
### os.dog integration: @osdog
###
####################################################################################

#	global variables, don`t change it
####################################################################################
CFG_FILENAME="miner.cfg"
dirname=$(dirname "$0")
[[ -f "$dirname/$CFG_FILENAME" ]] && . $dirname/$CFG_FILENAME

algo="ninja"
miner="ninja-miner"

API_TIMEOUT=2

# Get stats from API
json_data=$(curl -s --connect-timeout $API_TIMEOUT "http://localhost:$API_PORT/stats" 2>/dev/null)

total_hr=0
online=""
hr_json='[]'
busid_json='[]'

if [[ -n "$json_data" && "$json_data" != *"curl:"* && "$json_data" != *"error"* ]]; then
    # Extract version
    version=$(echo "$json_data" | jq -r '.version // "0.5.0"')

    # Online timestamp from uptime
    uptime_secs=$(echo "$json_data" | jq -r '.uptime_seconds // empty')
    if [[ -n "$uptime_secs" && "$uptime_secs" != "null" ]]; then
        online=$(( $(date +%s) - uptime_secs ))
    fi

    # Total hashrate = proofs_per_sec
    total_hr=$(echo "$json_data" | jq -r '.total_proofs_per_sec // 0' | cut -d'.' -f1)

    # Per-GPU data
    gpuCount=$(echo "$json_data" | jq '.gpus | length')

    if [[ "$gpuCount" -gt 0 ]]; then
        declare -a hr_data=()
        declare -a busid_data=()

        for (( i=0; i < gpuCount; i++ )); do
            # proofs_per_sec as hashrate
            gpu_hr=$(echo "$json_data" | jq -r ".gpus[$i].proofs_per_sec // 0" | cut -d'.' -f1)
            hr_data+=($gpu_hr)

            bus_id=$(echo "$json_data" | jq -r ".gpus[$i].bus_id // empty")
            if [[ -n "$bus_id" ]]; then
                busid_raw=$(echo "$bus_id" | cut -d':' -f1)
                busid=$(echo "$busid_raw" | tr '[:upper:]' '[:lower:]')
                [[ ${#busid} -eq 1 ]] && busid="0$busid"
                busid_data+=("$busid")
            fi
        done

        hr_json=$(printf '%s\n' "${hr_data[@]}" | jq -R . | jq -s .)
        busid_json=$(printf '%s\n' "${busid_data[@]}" | jq -R . | jq -s .)
    fi
fi

[[ -z "$version" ]] && version="0.5.0"

data=$(
    jq -n \
        --arg algo "$algo" \
        --arg miner "$miner" \
        --arg ver "$version" \
        --argjson busid "$busid_json" \
        --argjson hr "$hr_json" \
    '{
        $miner,
        $algo,
        $ver,
        total_hr: "'"$total_hr"'",
        busid: $busid,
        hr: $hr
    }'
)

if [[ -n "$online" ]]; then
    data=$(jq ". += {\"online\": $online}" <<< "$data")
fi

echo "$data" | jq -c
