#!/bin/bash

####################################################################################
###
### ninja-miner GPU stats
### os.dog integration: @osdog
###
####################################################################################

#	global variables, don`t change it
####################################################################################
CFG_FILENAME="miner.cfg"
dirname=$(dirname "$0")
[[ -f "$dirname/$CFG_FILENAME" ]] && . $dirname/$CFG_FILENAME

algo="ninja"
miner="ninja-miner"
LOG="/dog/log/ninja-miner.log"

maxDelay=120
time_now=$(date +%s)

# Get last stats line from log
last_line=$(grep -E 'GPU\[cuda-[0-9]+\]:.*h/s' "$LOG" 2>/dev/null | tail -n 1)

if [[ -z "$last_line" ]]; then
    echo '{"miner":"ninja-miner","algo":"ninja","hr":[],"busid":[],"total_hr":"0"}'
    exit 0
fi

# Check log freshness
ts_raw=$(echo "$last_line" | grep -oP '^\S+' | head -1)
time_rep=$(date -d "$ts_raw" +%s 2>/dev/null)
if [[ -z "$time_rep" ]]; then
    time_rep=$(date -d "$(echo "$ts_raw" | grep -oP '\d{2}:\d{2}:\d{2}')" +%s 2>/dev/null)
fi

if [[ -n "$time_rep" ]]; then
    diffTime=$(( time_now - time_rep ))
    diffTime=${diffTime#-}
else
    diffTime=0
fi

if [[ "$diffTime" -gt "$maxDelay" ]]; then
    echo '{"miner":"ninja-miner","algo":"ninja","hr":[],"busid":[],"total_hr":"0"}'
    exit 0
fi

# Parse per-GPU hashrates from log
# Format: NockGPU[cuda-0]: 426.9 h/s, 267.18 proofs/s | 21% util, 47C, 21W, mem 2039/8192MB
declare -A gpu_hashrates
while IFS= read -r line; do
    gpu_idx=$(echo "$line" | grep -oP 'GPU\[cuda-\K[0-9]+')
    hr=$(echo "$line" | grep -oP 'cuda-[0-9]+\]: \K[0-9]+\.?[0-9]*(?= h/s)')
    if [[ -n "$gpu_idx" && -n "$hr" ]]; then
        gpu_hashrates[$gpu_idx]="$hr"
    fi
done <<< "$(grep -E 'GPU\[cuda-[0-9]+\]:.*h/s' "$LOG" | tail -n 20)"

# Sort GPU indices
gpu_indices=($(echo "${!gpu_hashrates[@]}" | tr ' ' '\n' | sort -n))
gpu_count=${#gpu_indices[@]}

if [[ "$gpu_count" -eq 0 ]]; then
    echo '{"miner":"ninja-miner","algo":"ninja","hr":[],"busid":[],"total_hr":"0"}'
    exit 0
fi

# Build hashrate array and total
hash_arr=()
total_hs=0
for idx in "${gpu_indices[@]}"; do
    hr="${gpu_hashrates[$idx]}"
    hash_arr+=("$hr")
    total_hs=$(echo "$total_hs + $hr" | bc)
done

# Get bus IDs from nvidia-smi
busid_arr=()
if command -v nvidia-smi &>/dev/null; then
    while IFS=', ' read -r bus; do
        bus_hex=$(echo "$bus" | grep -oP '[0-9A-Fa-f]{2}(?=:[0-9A-Fa-f]{2}\.[0-9])')
        busid_arr+=("$(printf '%02x' $((16#${bus_hex:-0})))")
    done < <(nvidia-smi --query-gpu=pci.bus_id --format=csv,noheader,nounits 2>/dev/null)
fi

# Calculate online timestamp from log start
online=""
first_line=$(head -1 "$LOG" 2>/dev/null)
if [[ -n "$first_line" ]]; then
    ts_first=$(echo "$first_line" | grep -oP '^\S+' | head -1)
    online=$(date -d "$ts_first" +%s 2>/dev/null)
fi

# Build JSON
hr_json=$(printf '%s\n' "${hash_arr[@]}" | jq -R . | jq -s .)
busid_json=$(printf '%s\n' "${busid_arr[@]}" | jq -R . | jq -s .)

data=$(
    jq -n \
        --arg algo "$algo" \
        --arg miner "$miner" \
        --arg ver "0.2.0" \
        --argjson busid "$busid_json" \
        --argjson hr "$hr_json" \
    '{
        $miner,
        $algo,
        $ver,
        total_hr: "'"$total_hs"'",
        busid: $busid,
        hr: $hr
    }'
)

if [[ -n "$online" ]]; then
    data=$(jq ". += {\"online\": $online}" <<< "$data")
fi

echo "$data" | jq -c
